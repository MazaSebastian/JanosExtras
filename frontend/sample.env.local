# JWT Secret (OBLIGATORIO - generar un string aleatorio largo)
# Ejemplo: openssl rand -base64 32
JWT_SECRET=tu_jwt_secret_aqui

# Sentry (Monitoreo de errores)
# Obtén tu DSN en: https://sentry.io/settings/projects/
SENTRY_DSN=https://tu_dsn_aqui@o0000000.ingest.us.sentry.io/0000000
NEXT_PUBLIC_SENTRY_DSN=https://tu_dsn_aqui@o0000000.ingest.us.sentry.io/0000000

# Google Maps API Key
# Obtén tu API Key en: https://console.cloud.google.com/google/maps-apis
# Habilita: Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# OpenAI API Key (para chatbot con IA)
# Obtén tu API Key en: https://platform.openai.com/api-keys
# Requerido para Fase 2 del chatbot (IA)
OPENAI_API_KEY=sk-tu_api_key_aqui

# Google Calendar API (OAuth 2.0)
# Obtén las credenciales en: https://console.cloud.google.com/apis/credentials
# 1. Crear proyecto en Google Cloud Console
# 2. Habilitar Google Calendar API
# 3. Crear credenciales OAuth 2.0
# 4. Agregar URI de redirección: http://localhost:3000/api/google-calendar/callback (desarrollo)
#    y https://janosdjs.com/api/google-calendar/callback (producción)
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-calendar/callback

# Twilio WhatsApp Business API (para chat completo)
# Obtén tus credenciales en: https://console.twilio.com/
# Registro gratuito con $15.50 de crédito inicial
TWILIO_ACCOUNT_SID=tu_account_sid_aqui
TWILIO_AUTH_TOKEN=tu_auth_token_aqui
TWILIO_WHATSAPP_NUMBER=whatsapp:+5491123456789
# Formato: whatsapp:+[codigo_pais][numero]
# Ejemplo Argentina: whatsapp:+5491123456789

# Base de datos PostgreSQL (Producción)
# DATABASE_URL=postgresql://usuario:password@host:5432/base?sslmode=require
